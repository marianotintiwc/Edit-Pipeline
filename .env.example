API_NAME=UGC Visual UI API
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# RunPod
RUNPOD_API_KEY=replace-me
RUNPOD_ENDPOINT_ID=replace-me
RUNPOD_TIMEOUT_SECONDS=120

# Storage fallback (JSON files persisted on local disk)
RUNS_STORE_PATH=.data/runs_store.json
BATCH_STORE_PATH=.data/batch_store.json

# AWS (optional depending on deployment)
AWS_REGION=us-east-1
RUNS_TABLE_NAME=

# Auth (optional)
AUTH_ENABLED=false
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
