API_NAME=UGC Visual UI API
API_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174

# RunPod
RUNPOD_API_KEY=replace-me
RUNPOD_ENDPOINT_ID=replace-me
RUNPOD_TIMEOUT_SECONDS=120
RUNPOD_STATUS_TIMEOUT_SECONDS=15
RUNPOD_SUBMIT_MAX_RETRIES=3
RUNPOD_STATUS_MAX_RETRIES=2
RUNPOD_RETRY_BACKOFF_SECONDS=0.5

# Storage fallback (JSON files persisted on local disk)
RUNS_STORE_PATH=.data/runs_store.json
BATCH_STORE_PATH=.data/batch_store.json
IDEMPOTENCY_STORE_PATH=.data/idempotency_store.json
IDEMPOTENCY_TTL_SECONDS=86400
BATCH_REFRESH_MAX_ROWS=50
BATCH_REFRESH_MAX_WORKERS=8

# Hardening feature flags (staging/prod rollout controls)
ENABLE_HARDENING_JOB_IDEMPOTENCY=true
ENABLE_HARDENING_BATCH_IDEMPOTENCY=true
ENABLE_HARDENING_BATCH_REFRESH_QUERY=true
ENABLE_HARDENING_CONCURRENT_STATUS_REFRESH=true
ENABLE_HARDENING_RUNPOD_RETRY_POLICY=true

# AWS (optional depending on deployment)
AWS_REGION=us-east-1
RUNS_TABLE_NAME=

# Auth (optional)
AUTH_ENABLED=false
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
